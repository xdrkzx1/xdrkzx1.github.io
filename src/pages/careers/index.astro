---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { jobs } from '../../data/jobs';

const departments = [...new Set(jobs.map(j => j.department))];

const levelColors: Record<string, string> = {
  Senior: 'badge--blue',
  'Mid-level': 'badge--green',
  Manager: 'badge--orange',
  Director: 'badge--purple',
  Principal: 'badge--blue',
};

function timeAgo(dateStr: string) {
  const days = Math.floor((Date.now() - new Date(dateStr).getTime()) / (1000 * 60 * 60 * 24));
  if (days === 0) return 'Today';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  return `${Math.floor(days / 30)}mo ago`;
}
---

<BaseLayout
  title="Careers at Noshtek"
  description="Join Noshtek — a boutique AI + SAP finance consultancy where senior specialists do meaningful work for utilities, telecom, and insurance clients."
>
  <!-- Hero -->
  <section class="careers-hero">
    <div class="container careers-hero__inner">
      <span class="badge badge--orange">We're Hiring</span>
      <h1 class="careers-hero__heading">Build Your Career at the Intersection of AI and SAP Finance</h1>
      <p class="careers-hero__sub">We're a small, senior-weighted team working on genuinely complex SAP finance programmes. No fluff, no bench. Just serious work with serious people.</p>
      <div class="careers-hero__stats">
        <div class="c-stat"><span class="c-stat__val">{jobs.length}</span><span class="c-stat__label">Open positions</span></div>
        <div class="c-stat"><span class="c-stat__val">Senior-led</span><span class="c-stat__label">Team culture</span></div>
        <div class="c-stat"><span class="c-stat__val">Remote</span><span class="c-stat__label">Friendly roles</span></div>
      </div>
    </div>
  </section>

  <!-- Why Noshtek -->
  <section class="section why-noshtek">
    <div class="container">
      <div class="section-label reveal">Why Join Us</div>
      <h2 class="section-heading reveal">What Makes Noshtek Different to Work For</h2>
      <div class="perks-grid">
        <div class="perk-card reveal reveal-delay-1">
          <span class="perk-icon">🎯</span>
          <h3>Work on real complexity</h3>
          <p>IFRS 17 implementations, BRIM at scale, AI embedded in SAP — not internal tool upgrades or support tickets.</p>
        </div>
        <div class="perk-card reveal reveal-delay-2">
          <span class="perk-icon">👩‍💼</span>
          <h3>Senior peers, daily</h3>
          <p>Our team is deliberately small and experience-weighted. You'll work alongside Principals and Directors on every engagement.</p>
        </div>
        <div class="perk-card reveal reveal-delay-3">
          <span class="perk-icon">🚀</span>
          <h3>Career acceleration</h3>
          <p>No 8-year partner track. High performers at Noshtek progress fast because our clients notice — and reward — impact.</p>
        </div>
        <div class="perk-card reveal reveal-delay-4">
          <span class="perk-icon">🌍</span>
          <h3>Truly flexible work</h3>
          <p>Most of our roles are hybrid or fully remote. We evaluate output, not office attendance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Open Roles -->
  <section class="section open-roles">
    <div class="container">
      <div class="section-label reveal">Open Roles</div>
      <h2 class="section-heading reveal">Current Openings</h2>

      <!-- Filter -->
      <div class="jobs-filters reveal" role="group" aria-label="Filter by department">
        <button class="filter-btn is-active" data-filter="all">All</button>
        {departments.map(d => (
          <button class="filter-btn" data-filter={d}>{d}</button>
        ))}
      </div>

      <div class="jobs-list" id="jobs-list">
        {jobs.map(job => (
          <article class="job-card reveal" data-dept={job.department}>
            <div class="job-card__left">
              <div class="job-card__meta">
                <span class={`badge ${levelColors[job.level] ?? 'badge--grey'}`}>{job.level}</span>
                <span class="badge badge--grey">{job.type}</span>
                <span class="job-card__time">{timeAgo(job.postedDate)}</span>
              </div>
              <h2 class="job-card__title">{job.title}</h2>
              <p class="job-card__dept">{job.department} · {job.location}</p>
              <p class="job-card__desc">{job.description}</p>
            </div>
            <div class="job-card__right">
              <button class="accordion__trigger job-card__toggle" aria-expanded="false" aria-controls={`job-${job.id}`}>
                View Requirements
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </button>
              <a href="/contact" class="btn btn--primary btn--sm">Apply Now</a>
            </div>
            <div id={`job-${job.id}`} class="accordion__panel job-requirements">
              <div class="requirements-inner">
                <div class="req-col">
                  <p class="req-heading">Requirements</p>
                  <ul>
                    {job.requirements.map(r => (
                      <li>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        {r}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="req-col">
                  <p class="req-heading">Nice to Have</p>
                  <ul>
                    {job.niceToHave.map(n => (
                      <li>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                        {n}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Application -->
  <section class="section open-app">
    <div class="container">
      <div class="open-app__inner reveal">
        <div>
          <h2 class="open-app__heading">Don't see your role?</h2>
          <p class="open-app__sub">We're always interested in exceptional SAP Finance consultants and AI practitioners. Send us an open application.</p>
        </div>
        <a href="/contact" class="btn btn--primary">Send Open Application</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.job-card');
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const f = btn.dataset.filter;
      cards.forEach(card => {
        card.style.display = (f === 'all' || card.dataset.dept === f) ? '' : 'none';
      });
    });
  });
</script>

<style>
.careers-hero {
  background: linear-gradient(135deg, var(--color-blue) 0%, #0a4a78 100%);
  padding-block: var(--space-20) var(--space-16);
  color: var(--color-white);
}
.careers-hero__inner { max-width: 760px; }
.careers-hero__heading { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; color: var(--color-white); margin-block: var(--space-4) var(--space-5); }
.careers-hero__sub { font-size: var(--text-lg); color: rgba(255,255,255,0.8); line-height: 1.65; margin-bottom: var(--space-8); }
.careers-hero__stats { display: flex; gap: var(--space-10); flex-wrap: wrap; }
.c-stat__val { display: block; font-family: var(--font-heading); font-weight: 800; font-size: var(--text-2xl); color: var(--color-orange); line-height: 1; }
.c-stat__label { font-size: var(--text-sm); color: rgba(255,255,255,0.7); }

/* Why */
.why-noshtek { background: var(--color-surface); }
.perks-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); margin-top: var(--space-10); }
.perk-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); }
.perk-icon { font-size: 2rem; display: block; margin-bottom: var(--space-4); }
.perk-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-2); }
.perk-card p { font-size: var(--text-sm); color: var(--color-grey); line-height: 1.7; }

/* Badge variants */
.badge--blue { background: rgba(8,58,94,0.1); color: var(--color-blue); }
.badge--orange { background: rgba(255,142,1,0.12); color: #c47000; }
.badge--green { background: rgba(0,122,63,0.1); color: var(--color-green); }
.badge--grey { background: var(--color-surface); color: var(--color-grey); }
.badge--purple { background: rgba(90,50,140,0.1); color: #5a328c; }

/* Filters */
.jobs-filters { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-block: var(--space-6) var(--space-8); }
.filter-btn { padding: var(--space-2) var(--space-4); border: 1px solid var(--color-border); border-radius: 100px; background: var(--color-white); font-size: var(--text-sm); font-weight: 500; color: var(--color-grey); cursor: pointer; transition: all var(--transition-fast); }
.filter-btn:hover { border-color: var(--color-orange); color: var(--color-orange); }
.filter-btn.is-active { background: var(--color-orange); border-color: var(--color-orange); color: var(--color-white); font-weight: 600; }

/* Job Cards */
.jobs-list { display: flex; flex-direction: column; gap: var(--space-4); }
.job-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-7); display: grid; grid-template-columns: 1fr auto; grid-template-rows: auto auto; gap: var(--space-4) var(--space-6); transition: box-shadow var(--transition-fast); }
.job-card:hover { box-shadow: var(--shadow-md); }
.job-card__left { grid-column: 1; grid-row: 1; }
.job-card__right { grid-column: 2; grid-row: 1; display: flex; flex-direction: column; align-items: flex-end; gap: var(--space-3); }
.job-requirements { grid-column: 1 / -1; grid-row: 2; }
.job-card__meta { display: flex; gap: var(--space-2); align-items: center; margin-bottom: var(--space-3); flex-wrap: wrap; }
.job-card__time { font-size: var(--text-xs); color: var(--color-grey); }
.job-card__title { font-size: var(--text-xl); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-1); }
.job-card__dept { font-size: var(--text-sm); color: var(--color-grey); margin-bottom: var(--space-3); }
.job-card__desc { font-size: var(--text-sm); color: var(--color-text); line-height: 1.7; }
.job-card__toggle { display: flex; align-items: center; gap: var(--space-2); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-2) var(--space-4); font-size: var(--text-sm); font-weight: 500; cursor: pointer; color: var(--color-text); transition: all var(--transition-fast); white-space: nowrap; }
.job-card__toggle:hover { border-color: var(--color-orange); color: var(--color-orange); }
.job-card__toggle[aria-expanded="true"] svg { transform: rotate(180deg); }
.job-card__toggle svg { transition: transform var(--transition-fast); }

/* Requirements panel */
.job-requirements { display: none; border-top: 1px solid var(--color-border); padding-top: var(--space-5); }
.job-requirements.is-open { display: block; }
.requirements-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-8); }
.req-heading { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-grey); margin-bottom: var(--space-3); }
.req-col ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }
.req-col li { display: flex; align-items: flex-start; gap: var(--space-2); font-size: var(--text-sm); color: var(--color-text); line-height: 1.6; }
.req-col li svg { color: var(--color-orange); flex-shrink: 0; margin-top: 2px; }

/* Open App */
.open-app { background: var(--color-surface); }
.open-app__inner { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-8); display: flex; align-items: center; justify-content: space-between; gap: var(--space-8); flex-wrap: wrap; }
.open-app__heading { font-size: var(--text-xl); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-2); }
.open-app__sub { font-size: var(--text-sm); color: var(--color-grey); }

@media (max-width: 1000px) {
  .perks-grid { grid-template-columns: repeat(2, 1fr); }
  .job-card { grid-template-columns: 1fr; }
  .job-card__right { align-items: flex-start; flex-direction: row; }
  .requirements-inner { grid-template-columns: 1fr; }
}
@media (max-width: 600px) { .perks-grid { grid-template-columns: 1fr; } }
</style>
