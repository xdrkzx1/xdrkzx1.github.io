---
import BaseLayout from '../../layouts/BaseLayout.astro';

const offices = [
  {
    city: 'Toronto',
    country: 'Canada',
    flag: '🇨🇦',
    type: 'Headquarters',
    address: '100 King Street West, Suite 5700\nToronto, ON M5X 1C7',
    phone: '+1 416 555 0100',
    email: 'canada@noshtek.com',
    desc: 'Our global headquarters and the home of our insurance and utilities practices for North America.',
    focus: ['Insurance', 'Utilities', 'Canada-wide'],
  },
  {
    city: 'New York',
    country: 'United States',
    flag: '🇺🇸',
    type: 'US Office',
    address: '1271 Avenue of the Americas, 40th Floor\nNew York, NY 10020',
    phone: '+1 212 555 0200',
    email: 'us@noshtek.com',
    desc: 'Our US hub serving insurance, telecom, and utilities clients across the eastern seaboard and nationally.',
    focus: ['Insurance', 'Telecom', 'Financial Services'],
  },
  {
    city: 'Singapore',
    country: 'Singapore',
    flag: '🇸🇬',
    type: 'APAC Hub',
    address: '1 Raffles Place, #20-61\nSingapore 048616',
    phone: '+65 6555 0300',
    email: 'apac@noshtek.com',
    desc: 'Our APAC headquarters covering Singapore, Australia, and Southeast Asian markets.',
    focus: ['APAC Markets', 'Utilities', 'Insurance'],
  },
  {
    city: 'Taipei',
    country: 'Taiwan',
    flag: '🇹🇼',
    type: 'Regional Office',
    address: 'Xinyi Road, Sec. 5\nTaipei 110',
    phone: '+886 2 2555 0400',
    email: 'taiwan@noshtek.com',
    desc: 'Noshtek Taiwan supporting financial services and manufacturing clients across Taiwan and greater China.',
    focus: ['Financial Services', 'Manufacturing'],
  },
];
---

<BaseLayout
  title="Our Locations"
  description="Noshtek has offices in Toronto, New York, Singapore, and Taipei — delivering AI + SAP finance transformations across North America and APAC."
>
  <section class="locations-hero">
    <div class="container locations-hero__inner">
      <a href="/company" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        About Noshtek
      </a>
      <span class="badge badge--orange">Locations</span>
      <h1 class="locations-hero__heading">Where We Work</h1>
      <p class="locations-hero__sub">Offices across North America and Asia Pacific — with remote delivery capabilities for engagements wherever our clients operate.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="offices-grid">
        {offices.map((office, i) => (
          <div class={`office-card reveal reveal-delay-${i + 1}`}>
            <div class="office-card__header">
              <span class="office-flag">{office.flag}</span>
              <div>
                <h2 class="office-card__city">{office.city}</h2>
                <span class="office-card__type">{office.type}</span>
              </div>
            </div>
            <p class="office-card__desc">{office.desc}</p>
            <div class="office-card__focus">
              {office.focus.map(f => <span class="focus-tag">{f}</span>)}
            </div>
            <div class="office-card__contact">
              <div class="contact-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span>{office.address.replace('\n', ', ')}</span>
              </div>
              <div class="contact-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <a href={`tel:${office.phone.replace(/\s/g,'')}`}>{office.phone}</a>
              </div>
              <div class="contact-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <a href={`mailto:${office.email}`}>{office.email}</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-banner reveal">
    <div class="container cta-banner__inner">
      <div class="cta-banner__text">
        <h2 class="cta-banner__heading">We work where you work</h2>
        <p class="cta-banner__sub">Our consultants are experienced in hybrid and fully remote delivery. Reach out to the nearest office.</p>
      </div>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--white">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.locations-hero {
  background: linear-gradient(135deg, var(--color-blue) 0%, #0a4a78 100%);
  padding-block: var(--space-16);
  color: var(--color-white);
}
.locations-hero__inner { max-width: 680px; }
.back-link { display: inline-flex; align-items: center; gap: var(--space-1); color: rgba(255,255,255,0.7); text-decoration: none; font-size: var(--text-sm); margin-bottom: var(--space-5); transition: color var(--transition-fast); }
.back-link:hover { color: var(--color-white); }
.locations-hero__heading { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; color: var(--color-white); margin-block: var(--space-4) var(--space-5); }
.locations-hero__sub { font-size: var(--text-lg); color: rgba(255,255,255,0.8); line-height: 1.65; }

.offices-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
.office-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-7); display: flex; flex-direction: column; gap: var(--space-5); }
.office-card__header { display: flex; align-items: center; gap: var(--space-4); }
.office-flag { font-size: 2.5rem; }
.office-card__city { font-size: var(--text-xl); font-weight: 700; color: var(--color-blue); }
.office-card__type { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-orange); }
.office-card__desc { font-size: var(--text-sm); color: var(--color-grey); line-height: 1.7; }
.office-card__focus { display: flex; flex-wrap: wrap; gap: var(--space-2); }
.focus-tag { font-size: var(--text-xs); background: rgba(8,58,94,0.07); color: var(--color-blue); border-radius: 4px; padding: 4px 10px; font-weight: 600; }
.office-card__contact { display: flex; flex-direction: column; gap: var(--space-3); padding-top: var(--space-4); border-top: 1px solid var(--color-border); }
.contact-item { display: flex; align-items: flex-start; gap: var(--space-2); font-size: var(--text-sm); color: var(--color-grey); }
.contact-item svg { color: var(--color-orange); flex-shrink: 0; margin-top: 1px; }
.contact-item a { color: var(--color-blue); text-decoration: none; transition: color var(--transition-fast); }
.contact-item a:hover { color: var(--color-orange); }

@media (max-width: 768px) { .offices-grid { grid-template-columns: 1fr; } }
</style>
