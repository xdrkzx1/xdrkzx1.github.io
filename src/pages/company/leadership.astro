---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { team } from '../../data/team';
---

<BaseLayout
  title="Leadership & Experts"
  description="Meet the senior SAP finance specialists and AI practitioners who lead Noshtek's practice areas."
>
  <section class="leadership-hero">
    <div class="container leadership-hero__inner">
      <a href="/company" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        About Noshtek
      </a>
      <span class="badge badge--orange">Our Team</span>
      <h1 class="leadership-hero__heading">The Specialists Behind Your SAP Transformation</h1>
      <p class="leadership-hero__sub">Our team of SAP Finance practitioners, AI specialists, and industry experts bring decades of hands-on delivery experience to every engagement.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="team-grid">
        {team.map((member, i) => (
          <article class={`team-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="team-card__header">
              <div class="team-card__avatar">{member.initials}</div>
              <div>
                <h2 class="team-card__name">{member.name}</h2>
                <p class="team-card__title">{member.title}</p>
              </div>
            </div>
            <p class="team-card__bio">{member.bio}</p>
            <div class="team-card__expertise">
              <p class="team-card__expertise-label">Expertise</p>
              <div class="team-card__tags">
                {member.expertise.map(e => <span class="expertise-tag">{e}</span>)}
              </div>
            </div>
            <div class="team-card__industries">
              {member.industries.map(ind => <span class="industry-chip">{ind}</span>)}
            </div>
            {member.linkedin && (
              <a href={member.linkedin} class="team-card__linkedin" target="_blank" rel="noopener noreferrer" aria-label={`${member.name} on LinkedIn`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-banner reveal">
    <div class="container cta-banner__inner">
      <div class="cta-banner__text">
        <h2 class="cta-banner__heading">Work with our experts directly</h2>
        <p class="cta-banner__sub">Every engagement is led by a senior Noshtek specialist — not delegated to junior staff.</p>
      </div>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--white">Schedule a Call</a>
        <a href="/careers" class="btn btn--outline-white">Join Our Team</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.leadership-hero {
  background: linear-gradient(135deg, var(--color-blue) 0%, #0a4a78 100%);
  padding-block: var(--space-16);
  color: var(--color-white);
}
.leadership-hero__inner { max-width: 680px; }
.back-link { display: inline-flex; align-items: center; gap: var(--space-1); color: rgba(255,255,255,0.7); text-decoration: none; font-size: var(--text-sm); margin-bottom: var(--space-5); transition: color var(--transition-fast); }
.back-link:hover { color: var(--color-white); }
.leadership-hero__heading { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; color: var(--color-white); margin-block: var(--space-4) var(--space-5); }
.leadership-hero__sub { font-size: var(--text-lg); color: rgba(255,255,255,0.8); line-height: 1.65; }

.team-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-8); }
.team-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-8); display: flex; flex-direction: column; gap: var(--space-5); }
.team-card__header { display: flex; align-items: center; gap: var(--space-4); }
.team-card__avatar { width: 64px; height: 64px; border-radius: 50%; background: var(--color-blue); color: var(--color-white); display: flex; align-items: center; justify-content: center; font-family: var(--font-heading); font-weight: 800; font-size: var(--text-xl); flex-shrink: 0; }
.team-card__name { font-size: var(--text-xl); font-weight: 700; color: var(--color-blue); margin-bottom: 4px; }
.team-card__title { font-size: var(--text-sm); color: var(--color-grey); }
.team-card__bio { font-size: var(--text-sm); color: var(--color-text); line-height: 1.75; }
.team-card__expertise-label { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-grey); margin-bottom: var(--space-2); }
.team-card__tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }
.expertise-tag { font-size: var(--text-xs); background: rgba(8,58,94,0.07); color: var(--color-blue); border-radius: 4px; padding: 4px 10px; font-weight: 600; }
.team-card__industries { display: flex; gap: var(--space-2); flex-wrap: wrap; }
.industry-chip { font-size: var(--text-xs); background: rgba(255,142,1,0.1); color: #c47000; border-radius: 4px; padding: 4px 10px; font-weight: 600; }
.team-card__linkedin { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); font-weight: 600; color: var(--color-blue); text-decoration: none; transition: color var(--transition-fast); }
.team-card__linkedin:hover { color: var(--color-orange); }

@media (max-width: 900px) { .team-grid { grid-template-columns: 1fr; } }
</style>
