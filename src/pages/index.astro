---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFeaturedInsights } from '../data/insights';
import { getFeaturedCaseStudies } from '../data/caseStudies';

const featuredInsights = getFeaturedInsights(3);
const featuredStories  = getFeaturedCaseStudies(3);
---

<BaseLayout
  title="Home"
  description="Noshtek is a boutique AI + SAP financial transformation partner for utilities, telecom, and insurance enterprises. SAP S/4HANA, BRIM, FPSL, PaPM and AI for regulated industries."
>

<!-- ============================================================
     1. HERO
     ============================================================ -->
<section class="hero" aria-label="Hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__kicker reveal">
        <span class="badge badge--orange">AI + SAP Financial Transformation</span>
      </div>
      <h1 class="hero__title reveal reveal-delay-1">
        Where AI Meets<br/>
        <span class="hero__title-accent">SAP Finance</span>
      </h1>
      <p class="hero__subtitle reveal reveal-delay-2">
        We modernise billing, financial close, and profitability for utilities, telecom, and insurance enterprises — with senior SAP expertise and financial-grade AI built in from day one.
      </p>
      <div class="hero__badges reveal reveal-delay-3">
        <span class="industry-badge">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Utilities
        </span>
        <span class="industry-badge">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Telecom
        </span>
        <span class="industry-badge">
          <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Insurance
        </span>
      </div>
      <div class="hero__actions reveal reveal-delay-4">
        <a href="/contact" class="btn btn--primary btn--lg">Talk to an Expert</a>
        <a href="/customer-stories" class="btn btn--secondary-white btn--lg">View Customer Stories</a>
      </div>
    </div>

    <!-- Hero visual: animated data network -->
    <div class="hero__visual reveal reveal-delay-2" aria-hidden="true">
      <div class="hero-viz">
        <svg class="hero-viz__svg" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Grid lines -->
          <line x1="0" y1="80"  x2="480" y2="80"  stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="0" y1="160" x2="480" y2="160" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="0" y1="240" x2="480" y2="240" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="0" y1="320" x2="480" y2="320" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="0" y1="400" x2="480" y2="400" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="80"  y1="0" x2="80"  y2="480" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="160" y1="0" x2="160" y2="480" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="240" y1="0" x2="240" y2="480" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="320" y1="0" x2="320" y2="480" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
          <line x1="400" y1="0" x2="400" y2="480" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>

          <!-- Connection lines -->
          <line x1="240" y1="240" x2="80"  y2="120" stroke="rgba(255,142,1,0.25)" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="240" y1="240" x2="400" y2="120" stroke="rgba(255,142,1,0.25)" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="240" y1="240" x2="80"  y2="360" stroke="rgba(255,142,1,0.25)" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="240" y1="240" x2="400" y2="360" stroke="rgba(255,142,1,0.25)" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="240" y1="240" x2="240" y2="80"  stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="240" y1="240" x2="240" y2="400" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="80"  y1="120" x2="400" y2="120" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
          <line x1="80"  y1="360" x2="400" y2="360" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>

          <!-- Central node -->
          <circle cx="240" cy="240" r="28" fill="rgba(255,142,1,0.15)" stroke="#ff8e01" stroke-width="2"/>
          <circle cx="240" cy="240" r="16" fill="#ff8e01"/>
          <!-- AI label -->
          <text x="240" y="245" text-anchor="middle" font-family="Montserrat,sans-serif" font-size="9" font-weight="700" fill="white">AI</text>

          <!-- Satellite nodes -->
          <circle cx="80"  cy="120" r="18" fill="rgba(8,58,94,0.8)"  stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
          <text x="80"  y="125" text-anchor="middle" font-size="7" font-weight="600" fill="rgba(255,255,255,0.8)" font-family="Montserrat,sans-serif">S/4H</text>

          <circle cx="400" cy="120" r="18" fill="rgba(8,58,94,0.8)"  stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
          <text x="400" y="125" text-anchor="middle" font-size="7" font-weight="600" fill="rgba(255,255,255,0.8)" font-family="Montserrat,sans-serif">BRIM</text>

          <circle cx="80"  cy="360" r="18" fill="rgba(8,58,94,0.8)"  stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
          <text x="80"  y="365" text-anchor="middle" font-size="7" font-weight="600" fill="rgba(255,255,255,0.8)" font-family="Montserrat,sans-serif">PaPM</text>

          <circle cx="400" cy="360" r="18" fill="rgba(8,58,94,0.8)"  stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
          <text x="400" y="365" text-anchor="middle" font-size="7" font-weight="600" fill="rgba(255,255,255,0.8)" font-family="Montserrat,sans-serif">FPSL</text>

          <circle cx="240" cy="80"  r="18" fill="rgba(8,58,94,0.8)"  stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
          <text x="240" y="85"  text-anchor="middle" font-size="7" font-weight="600" fill="rgba(255,255,255,0.8)" font-family="Montserrat,sans-serif">BTP</text>

          <circle cx="240" cy="400" r="18" fill="rgba(8,58,94,0.8)"  stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
          <text x="240" y="405" text-anchor="middle" font-size="7" font-weight="600" fill="rgba(255,255,255,0.8)" font-family="Montserrat,sans-serif">SAC</text>

          <!-- Pulse rings on central node -->
          <circle cx="240" cy="240" r="40" fill="none" stroke="rgba(255,142,1,0.2)" stroke-width="1" class="pulse-ring pulse-ring-1"/>
          <circle cx="240" cy="240" r="60" fill="none" stroke="rgba(255,142,1,0.1)" stroke-width="1" class="pulse-ring pulse-ring-2"/>
        </svg>

        <!-- Floating metric cards -->
        <div class="hero-metric hero-metric--1">
          <span class="hero-metric__value">3 days</span>
          <span class="hero-metric__label">Faster close</span>
        </div>
        <div class="hero-metric hero-metric--2">
          <span class="hero-metric__value">99.9%</span>
          <span class="hero-metric__label">Billing accuracy</span>
        </div>
        <div class="hero-metric hero-metric--3">
          <span class="hero-metric__value">80%</span>
          <span class="hero-metric__label">Auto-reconciliation</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <svg width="24" height="24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>


<!-- ============================================================
     2. VALUE PILLARS
     ============================================================ -->
<section class="section section--subtle" aria-label="Value pillars">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="section-label">What We Do</span>
      <h2 class="section-title">Four pillars. One integrated transformation.</h2>
      <p class="section-subtitle">Noshtek combines deep SAP expertise with financial-grade AI to deliver measurable outcomes across your entire financial operation.</p>
    </div>

    <div class="pillars-grid">
      {[
        {
          icon: '🏛️',
          title: 'Modernise Your Financial Core',
          desc: 'SAP S/4HANA Finance and Central Finance implementations that replace legacy ERP complexity with a clean, scalable foundation.',
          href: '/solutions/financial-transformation',
          color: '#083a5e',
          delay: 1,
        },
        {
          icon: '💳',
          title: 'Transform Billing & Revenue',
          desc: 'SAP BRIM and FI-CA solutions that handle millions of billing events daily with accuracy, automation, and AI-enhanced collections.',
          href: '/solutions/intelligent-revenue-billing',
          color: '#007a3f',
          delay: 2,
        },
        {
          icon: '📊',
          title: 'Unlock Profitability Intelligence',
          desc: 'SAP PaPM and Analytics Cloud implementations that give your CFO real-time visibility into margins by product, customer, and segment.',
          href: '/solutions/profitability-performance',
          color: '#0d5080',
          delay: 3,
        },
        {
          icon: '🤖',
          title: 'Embed AI Into Every Decision',
          desc: 'Financial-grade AI models — for reconciliations, forecasting, anomaly detection — built directly into your SAP workflows, not bolted on.',
          href: '/solutions/ai-for-sap-finance',
          color: '#ff8e01',
          delay: 4,
        },
      ].map((p) => (
        <a href={p.href} class={`pillar-card reveal reveal-delay-${p.delay}`}>
          <span class="pillar-card__icon" style={`background: ${p.color}18; color: ${p.color}`}>{p.icon}</span>
          <h3 class="pillar-card__title">{p.title}</h3>
          <p class="pillar-card__desc">{p.desc}</p>
          <span class="pillar-card__cta">
            Learn more
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>


<!-- ============================================================
     3. INDUSTRY FOCUS
     ============================================================ -->
<section class="section" aria-label="Industries we serve">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Industries</span>
      <h2 class="section-title">Deep expertise where it matters most</h2>
      <p class="section-subtitle">Noshtek focuses on three regulated industries where SAP finance and billing complexity is highest — and where our depth creates competitive advantage.</p>
    </div>

    <div class="industries-grid">
      {[
        {
          icon: '🛡️',
          name: 'Insurance',
          headline: 'Navigate IFRS 17 and billing modernisation with confidence',
          challenges: ['IFRS 17 & regulatory compliance', 'Complex policy billing (FS-CD)', 'Reinsurance accounting', 'Profitability by LOB'],
          href: '/industries/insurance',
          delay: 1,
        },
        {
          icon: '⚡',
          name: 'Utilities',
          headline: 'Power the energy transition with smart metering and finance at scale',
          challenges: ['Smart meter volume billing', 'SAP BRIM for interval data', 'Regulatory price controls', 'S/4HANA migration'],
          href: '/industries/utilities',
          delay: 2,
        },
        {
          icon: '📡',
          name: 'Telecom',
          headline: 'Monetise 5G and convergent services without revenue leakage',
          challenges: ['Convergent billing (fixed + mobile)', 'Revenue assurance', '5G service monetisation', 'Partner settlement'],
          href: '/industries/telecom',
          delay: 3,
        },
      ].map((ind) => (
        <div class={`industry-card reveal reveal-delay-${ind.delay}`}>
          <div class="industry-card__header">
            <span class="industry-card__icon">{ind.icon}</span>
            <span class="badge badge--blue">{ind.name}</span>
          </div>
          <h3 class="industry-card__title">{ind.headline}</h3>
          <ul class="industry-card__challenges">
            {ind.challenges.map(c => (
              <li>
                <svg width="14" height="14" fill="none" stroke="#007a3f" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                {c}
              </li>
            ))}
          </ul>
          <a href={ind.href} class="industry-card__link">
            Explore {ind.name} solutions
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ============================================================
     4. FEATURED CUSTOMER STORIES
     ============================================================ -->
<section class="section section--subtle" aria-label="Customer stories">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Customer Stories</span>
      <h2 class="section-title">Proven outcomes. Real clients.</h2>
      <p class="section-subtitle">See how leading utilities, insurers, and telecoms have transformed their financial operations with Noshtek.</p>
    </div>

    <div class="stories-grid">
      {featuredStories.map((story, i) => (
        <a href={`/customer-stories/${story.slug}`} class={`story-card reveal reveal-delay-${i + 1}`}>
          <div class="story-card__header">
            <span class="badge badge--blue">{story.industry}</span>
            <span class="story-card__region">{story.region}</span>
          </div>
          <h3 class="story-card__client">{story.client}</h3>
          <p class="story-card__challenge">{story.challenge.slice(0, 140)}…</p>
          <div class="story-card__outcomes">
            {story.outcomes.slice(0, 2).map(o => (
              <div class="story-outcome">
                <span class="story-outcome__value">{o.value}</span>
                <span class="story-outcome__label">{o.metric}</span>
              </div>
            ))}
          </div>
          <span class="story-card__cta">
            Read case study
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>

    <div class="text-center" style="margin-top: var(--space-10)">
      <a href="/customer-stories" class="btn btn--secondary btn--lg">Explore all customer stories</a>
    </div>
  </div>
</section>


<!-- ============================================================
     5. THOUGHT LEADERSHIP
     ============================================================ -->
<section class="section" aria-label="Thought leadership">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="section-label">Insights</span>
      <h2 class="section-title">SAP finance intelligence from the field</h2>
      <p class="section-subtitle">Practical guidance from the consultants who build and run these systems — not marketing content.</p>
    </div>

    <div class="insights-grid">
      {featuredInsights.map((insight, i) => (
        <a href={`/insights/${insight.slug}`} class={`insight-card reveal reveal-delay-${i + 1}`}>
          <div class="insight-card__meta">
            <span class={`badge ${insight.format === 'Report' ? 'badge--orange' : 'badge--blue'}`}>{insight.format}</span>
            {insight.gated && (
              <span class="gated-badge">
                <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
                Gated
              </span>
            )}
          </div>
          <h3 class="insight-card__title">{insight.title}</h3>
          <p class="insight-card__summary">{insight.summary.slice(0, 120)}…</p>
          <div class="insight-card__author">
            <span class="author-avatar">{insight.author.split(' ').map(n => n[0]).join('')}</span>
            <div>
              <p class="author-name">{insight.author}</p>
              <p class="author-role-text">{insight.readTime} min read · {new Date(insight.publishDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center" style="margin-top: var(--space-10)">
      <a href="/insights" class="btn btn--secondary btn--lg">View all insights</a>
    </div>
  </div>
</section>


<!-- ============================================================
     6. TRUST & CREDIBILITY
     ============================================================ -->
<section class="section section--dark" aria-label="Trust and credibility">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="section-label" style="color: var(--color-orange)">Why Noshtek</span>
      <h2 class="section-title" style="color: var(--color-white)">Senior expertise. Proven delivery. Focused verticals.</h2>
    </div>

    <!-- Stats -->
    <div class="trust-stats reveal">
      {[
        { value: '200+', label: 'SAP finance projects delivered' },
        { value: '18+', label: 'Years of SAP expertise' },
        { value: '50+', label: 'Enterprise clients worldwide' },
        { value: '3', label: 'Focused industry verticals' },
      ].map(s => (
        <div class="trust-stat">
          <span class="trust-stat__value">{s.value}</span>
          <span class="trust-stat__label">{s.label}</span>
        </div>
      ))}
    </div>

    <!-- Differentiators -->
    <div class="grid-3" style="margin-top: var(--space-12)">
      {[
        {
          icon: '👥',
          title: 'Senior-Led Delivery',
          desc: 'Every Noshtek engagement is staffed by senior consultants — not junior graduates. Your implementation is led by the people who pitched it.',
          delay: 1,
        },
        {
          icon: '🎯',
          title: 'Vertical Specialists',
          desc: 'We don\'t do everything. We specialise in three regulated industries where our knowledge of SAP, regulation, and business process is deepest.',
          delay: 2,
        },
        {
          icon: '🌐',
          title: 'North American Focus, Global Delivery',
          desc: 'Headquartered in North America with affiliate teams in Singapore and Taiwan — giving you senior on-shore leadership and global delivery capability.',
          delay: 3,
        },
      ].map((d) => (
        <div class={`card card--dark reveal reveal-delay-${d.delay}`}>
          <span class="card-icon">{d.icon}</span>
          <h3 class="card-title" style="color: var(--color-white)">{d.title}</h3>
          <p class="card-desc" style="color: rgba(255,255,255,0.7)">{d.desc}</p>
        </div>
      ))}
    </div>

    <!-- Client logos placeholder -->
    <div class="client-logos reveal" style="margin-top: var(--space-12)">
      <p class="client-logos__label">Trusted by leading enterprises in</p>
      <div class="client-logos__grid">
        {['Insurance', 'Utilities', 'Telecom', 'Energy', 'Financial Services'].map(sector => (
          <span class="client-logo-badge">{sector}</span>
        ))}
      </div>
    </div>
  </div>
</section>


<!-- ============================================================
     7. PARTNER ECOSYSTEM
     ============================================================ -->
<section class="section section--subtle" aria-label="Partner ecosystem">
  <div class="container">
    <div class="section-header section-header--center reveal">
      <span class="section-label">Partners</span>
      <h2 class="section-title">Built on the SAP ecosystem</h2>
      <p class="section-subtitle">Noshtek is an SAP Gold Partner with deep product certifications across the SAP finance and billing portfolio.</p>
    </div>

    <div class="partners-showcase reveal">
      <!-- SAP Gold Partner badge -->
      <div class="sap-badge">
        <svg class="sap-logo" viewBox="0 0 120 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="SAP" role="img">
          <rect width="120" height="48" rx="6" fill="#0070F2"/>
          <text x="60" y="32" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="22" fill="white">SAP</text>
        </svg>
        <div>
          <p class="sap-badge__tier">Gold Partner</p>
          <p class="sap-badge__desc">Recognised expertise in SAP S/4HANA Finance, BRIM, FPSL, PaPM, and BTP</p>
        </div>
      </div>

      <!-- Product certifications -->
      <div class="certifications-grid">
        {['SAP S/4HANA Finance', 'SAP BRIM', 'SAP FPSL', 'SAP PaPM', 'SAP BTP', 'SAP Analytics Cloud', 'SAP BW/4HANA', 'SAP TRM'].map(cert => (
          <span class="cert-badge">{cert}</span>
        ))}
      </div>
    </div>

    <div class="text-center" style="margin-top: var(--space-8)">
      <a href="/partners" class="btn btn--ghost">
        Learn about our partnerships
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>


<!-- ============================================================
     8. CLOSING CTA
     ============================================================ -->
<section class="cta-banner" aria-label="Get started">
  <div class="container">
    <div class="reveal">
      <span class="section-label" style="color: var(--color-orange)">Ready to Transform?</span>
      <h2 class="cta-banner__title">Ready to modernise your financial operations?</h2>
      <p class="cta-banner__text">Talk to an SAP + AI specialist or explore our resources to understand how Noshtek can help your organisation.</p>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--primary btn--lg">Request a consultation</a>
        <a href="/insights" class="btn btn--secondary-white btn--lg">Download insights</a>
        <a href="/contact#newsletter" class="btn btn--ghost" style="color: rgba(255,255,255,0.8)">Subscribe to newsletter</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
/* ---- Hero ---- */
.hero {
  background: linear-gradient(135deg, #052a45 0%, #083a5e 50%, #0d5080 100%);
  color: var(--color-white);
  padding-block: var(--space-24) var(--space-20);
  position: relative;
  overflow: hidden;
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hero::before {
  content: '';
