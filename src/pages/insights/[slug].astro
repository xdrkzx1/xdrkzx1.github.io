---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { insights, type InsightFormat } from '../../data/insights';

export function getStaticPaths() {
  return insights.map(i => ({ params: { slug: i.slug }, props: { insight: i } }));
}

const { insight } = Astro.props;

const formatColors: Record<InsightFormat, string> = {
  Article: 'badge--blue',
  Report: 'badge--orange',
  Webinar: 'badge--green',
  Guide: 'badge--grey',
  Event: 'badge--purple',
};

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const related = insights.filter(i =>
  i.slug !== insight.slug &&
  (i.industries.some(ind => insight.industries.includes(ind)) ||
   i.topics.some(t => insight.topics.includes(t)))
).slice(0, 3);
---

<BaseLayout
  title={insight.title}
  description={insight.summary}
>
  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container breadcrumb-inner">
      <a href="/insights">← Insights</a>
      <span class={`badge ${formatColors[insight.format]}`}>{insight.format}</span>
    </div>
  </div>

  <!-- Article Hero -->
  <section class="article-hero">
    <div class="container article-hero__inner">
      <div class="article-hero__text">
        <div class="article-hero__meta">
          {insight.industries.map(ind => <span class="industry-tag">{ind}</span>)}
        </div>
        <h1 class="article-hero__title">{insight.title}</h1>
        <p class="article-hero__summary">{insight.summary}</p>
        <div class="article-hero__author">
          <div class="author-avatar">{insight.author.split(' ').map(n => n[0]).join('').slice(0,2)}</div>
          <div>
            <span class="author-name">{insight.author}</span>
            <span class="author-role">{insight.authorRole}</span>
          </div>
          <div class="article-hero__date">
            <span>{formatDate(insight.publishDate)}</span>
            <span>{insight.readTime} min read</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gated gate -->
  {insight.gated ? (
    <section class="section">
      <div class="container article-layout">
        <article class="article-body">
          <div class="prose" set:html={insight.content.split('\n\n').slice(0,3).map(p => `<p>${p.replace(/\n/g,'<br>')}</p>`).join('')} />
          <div class="gated-gate">
            <div class="gated-gate__inner">
              <div class="gated-gate__icon">🔒</div>
              <h3 class="gated-gate__heading">Access the Full {insight.format}</h3>
              <p class="gated-gate__sub">Complete the short form below to download this resource.</p>
              <form class="gated-form" aria-label="Resource access form">
                <div class="form-row">
                  <div class="form-group">
                    <label class="form-label" for="gate-firstname">First Name</label>
                    <input class="form-input" id="gate-firstname" type="text" required />
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="gate-lastname">Last Name</label>
                    <input class="form-input" id="gate-lastname" type="text" required />
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label" for="gate-email">Work Email</label>
                  <input class="form-input" id="gate-email" type="email" required />
                </div>
                <div class="form-group">
                  <label class="form-label" for="gate-company">Company</label>
                  <input class="form-input" id="gate-company" type="text" required />
                </div>
                <button type="submit" class="btn btn--primary btn--full">Get Access</button>
              </form>
            </div>
          </div>
        </article>
        <aside class="article-sidebar">
          <div class="sidebar-block">
            <p class="sidebar-block__label">SAP Products</p>
            <div class="sidebar-tags">
              {insight.sapProducts.map(p => <span class="sidebar-tag">{p}</span>)}
            </div>
          </div>
          <div class="sidebar-block">
            <p class="sidebar-block__label">Topics</p>
            <div class="sidebar-tags">
              {insight.topics.map(t => <span class="sidebar-tag">{t}</span>)}
            </div>
          </div>
          <div class="sidebar-cta">
            <p class="sidebar-cta__text">Need help with this topic?</p>
            <a href="/contact" class="btn btn--primary btn--sm btn--full">Talk to a Specialist</a>
          </div>
        </aside>
      </div>
    </section>
  ) : (
    <section class="section">
      <div class="container article-layout">
        <article class="article-body">
          <div class="prose" set:html={insight.content
            .replace(/^## (.+)$/gm, '<h2>$1</h2>')
            .replace(/^### (.+)$/gm, '<h3>$1</h3>')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/^(\d+)\.\s\*\*(.+?)\*\*: (.+)$/gm, '<p><strong>$1. $2:</strong> $3</p>')
            .replace(/\n\n/g, '</p><p>')
            .replace(/^<p>(<h[23]>)/, '$1')
            .replace(/(<\/h[23]>)<\/p>/, '$1')
          } />
        </article>
        <aside class="article-sidebar">
          <div class="sidebar-block">
            <p class="sidebar-block__label">SAP Products</p>
            <div class="sidebar-tags">
              {insight.sapProducts.map(p => <span class="sidebar-tag">{p}</span>)}
            </div>
          </div>
          <div class="sidebar-block">
            <p class="sidebar-block__label">Topics</p>
            <div class="sidebar-tags">
              {insight.topics.map(t => <span class="sidebar-tag">{t}</span>)}
            </div>
          </div>
          <div class="sidebar-block">
            <p class="sidebar-block__label">Industries</p>
            <div class="sidebar-tags">
              {insight.industries.map(i => <span class="sidebar-tag">{i}</span>)}
            </div>
          </div>
          <div class="sidebar-cta">
            <p class="sidebar-cta__text">Need help applying this?</p>
            <a href="/contact" class="btn btn--primary btn--sm btn--full">Talk to a Specialist</a>
          </div>
        </aside>
      </div>
    </section>
  )}

  <!-- Related -->
  {related.length > 0 && (
    <section class="section related-section">
      <div class="container">
        <h2 class="section-heading reveal">Related Insights</h2>
        <div class="related-grid">
          {related.map(r => (
            <a href={`/insights/${r.slug}`} class="related-card reveal">
              <span class={`badge ${formatColors[r.format]}`}>{r.format}</span>
              <h3 class="related-card__title">{r.title}</h3>
              <p class="related-card__summary">{r.summary}</p>
              <span class="related-card__meta">{r.readTime} min · {formatDate(r.publishDate)}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
/* Breadcrumb */
.breadcrumb-bar { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding-block: var(--space-3); }
.breadcrumb-inner { display: flex; align-items: center; gap: var(--space-4); }
.breadcrumb-inner a { font-size: var(--text-sm); color: var(--color-grey); text-decoration: none; transition: color var(--transition-fast); }
.breadcrumb-inner a:hover { color: var(--color-blue); }

/* Badge variants */
.badge--blue { background: rgba(8,58,94,0.1); color: var(--color-blue); }
.badge--orange { background: rgba(255,142,1,0.12); color: #c47000; }
.badge--green { background: rgba(0,122,63,0.1); color: var(--color-green); }
.badge--grey { background: var(--color-surface); color: var(--color-grey); }
.badge--purple { background: rgba(90,50,140,0.1); color: #5a328c; }

/* Article Hero */
.article-hero {
  background: var(--color-blue);
  padding-block: var(--space-12) var(--space-10);
  color: var(--color-white);
}
.article-hero__inner { max-width: 800px; }
.article-hero__meta { display: flex; gap: var(--space-2); margin-bottom: var(--space-4); }
.industry-tag { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.9); border: 1px solid rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 100px; font-size: var(--text-xs); font-weight: 600; }
.article-hero__title { font-size: clamp(1.6rem, 3.5vw, 2.5rem); font-weight: 800; line-height: 1.2; color: var(--color-white); margin-bottom: var(--space-5); }
.article-hero__summary { font-size: var(--text-lg); color: rgba(255,255,255,0.8); line-height: 1.65; margin-bottom: var(--space-7); }
.article-hero__author { display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; }
.author-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--color-orange); color: var(--color-white); display: flex; align-items: center; justify-content: center; font-size: var(--text-sm); font-weight: 700; flex-shrink: 0; }
.author-name { display: block; font-weight: 600; color: var(--color-white); font-size: var(--text-sm); }
.author-role { display: block; font-size: var(--text-xs); color: rgba(255,255,255,0.65); }
.article-hero__date { margin-left: auto; text-align: right; }
.article-hero__date span { display: block; font-size: var(--text-xs); color: rgba(255,255,255,0.6); }

/* Layout */
.article-layout { display: grid; grid-template-columns: 1fr 280px; gap: var(--space-12); align-items: start; }
.article-body { min-width: 0; }

/* Sidebar */
.article-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: var(--space-5); }
.sidebar-block { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-5); }
.sidebar-block__label { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-grey); margin-bottom: var(--space-3); }
.sidebar-tags { display: flex; flex-wrap: wrap; gap: var(--space-2); }
.sidebar-tag { font-size: var(--text-xs); background: var(--color-surface); border-radius: var(--radius-sm); padding: 4px 10px; color: var(--color-grey); font-weight: 500; }
.sidebar-cta { background: var(--color-blue); border-radius: var(--radius-lg); padding: var(--space-5); }
.sidebar-cta__text { font-size: var(--text-sm); color: rgba(255,255,255,0.85); margin-bottom: var(--space-3); }

/* Gated */
.gated-gate { position: relative; margin-top: var(--space-8); }
.gated-gate::before { content: ''; position: absolute; bottom: 100%; left: 0; right: 0; height: 100px; background: linear-gradient(to bottom, transparent, white); pointer-events: none; }
.gated-gate__inner { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-8); text-align: center; max-width: 480px; margin: 0 auto; }
.gated-gate__icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
.gated-gate__heading { font-size: var(--text-xl); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-3); }
.gated-gate__sub { font-size: var(--text-sm); color: var(--color-grey); margin-bottom: var(--space-6); }
.gated-form { display: flex; flex-direction: column; gap: var(--space-4); text-align: left; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
.btn--full { width: 100%; justify-content: center; }

/* Related */
.related-section { background: var(--color-surface); }
.related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); margin-top: var(--space-8); }
.related-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); text-decoration: none; display: flex; flex-direction: column; gap: var(--space-3); transition: box-shadow var(--transition-fast), transform var(--transition-fast); }
.related-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
.related-card__title { font-size: var(--text-base); font-weight: 700; color: var(--color-blue); line-height: 1.4; flex: 1; }
.related-card__summary { font-size: var(--text-sm); color: var(--color-grey); line-height: 1.65; }
.related-card__meta { font-size: var(--text-xs); color: var(--color-grey); margin-top: auto; }

@media (max-width: 900px) {
  .article-layout { grid-template-columns: 1fr; }
  .article-sidebar { position: static; }
  .related-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
</style>
