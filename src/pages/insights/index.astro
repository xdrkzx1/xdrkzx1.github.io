---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { insights, type InsightFormat } from '../../data/insights';

const formats: InsightFormat[] = ['Article', 'Report', 'Webinar', 'Guide', 'Event'];
const allTopics = [...new Set(insights.flatMap(i => i.topics))].slice(0, 8);

const formatColors: Record<InsightFormat, string> = {
  Article: 'badge--blue',
  Report: 'badge--orange',
  Webinar: 'badge--green',
  Guide: 'badge--grey',
  Event: 'badge--purple',
};

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const featured = insights.filter(i => i.featured);
const rest = insights.filter(i => !i.featured);
---

<BaseLayout
  title="Insights & Resources"
  description="Practical AI + SAP finance insights, guides, and reports for CFOs and finance leaders in utilities, telecom, and insurance."
>
  <!-- Hero -->
  <section class="insights-hero">
    <div class="container insights-hero__inner">
      <span class="badge badge--orange">Insights</span>
      <h1 class="insights-hero__heading">AI + SAP Finance<br/>Insights & Resources</h1>
      <p class="insights-hero__sub">Practical thinking from our specialists — SAP finance, AI, and industry perspectives designed for CFOs and finance leaders in regulated industries.</p>
    </div>
  </section>

  <!-- Featured -->
  {featured.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-label reveal">Featured</div>
        <div class="featured-grid">
          {featured.map((ins, i) => (
            <a href={`/insights/${ins.slug}`} class={`featured-card reveal reveal-delay-${i + 1} ${i === 0 ? 'featured-card--large' : ''}`}>
              <div class="featured-card__meta">
                <span class={`badge ${formatColors[ins.format]}`}>{ins.format}</span>
                {ins.gated && <span class="badge badge--grey">Gated</span>}
              </div>
              <h2 class="featured-card__title">{ins.title}</h2>
              <p class="featured-card__summary">{ins.summary}</p>
              <div class="featured-card__footer">
                <div class="author-info">
                  <div class="author-avatar">{ins.author.split(' ').map(n => n[0]).join('').slice(0,2)}</div>
                  <div>
                    <span class="author-name">{ins.author}</span>
                    <span class="author-meta">{ins.readTime} min read · {formatDate(ins.publishDate)}</span>
                  </div>
                </div>
                <span class="read-more">Read →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All Insights -->
  <section class="section insights-all">
    <div class="container">
      <h2 class="section-heading reveal">All Insights</h2>

      <!-- Filter bar -->
      <div class="insights-filters reveal" role="group" aria-label="Filter insights by format">
        <button class="filter-btn is-active" data-filter="all">All</button>
        {formats.map(f => (
          <button class="filter-btn" data-filter={f}>{f}</button>
        ))}
      </div>

      <div class="insights-grid" id="insights-grid">
        {rest.map((ins) => (
          <a href={`/insights/${ins.slug}`} class="insight-card" data-format={ins.format}>
            <div class="insight-card__top">
              <span class={`badge ${formatColors[ins.format]}`}>{ins.format}</span>
              {ins.gated && (
                <span class="insight-card__gated">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1C8.676 1 6 3.676 6 7v1H4v15h16V8h-2V7c0-3.324-2.676-6-6-6zm0 2c2.276 0 4 1.724 4 4v1H8V7c0-2.276 1.724-4 4-4zm0 9a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/></svg>
                  Gated
                </span>
              )}
            </div>
            <h3 class="insight-card__title">{ins.title}</h3>
            <p class="insight-card__summary">{ins.summary}</p>
            <div class="insight-card__footer">
              <div class="insight-tags">
                {ins.industries.slice(0, 2).map(ind => (
                  <span class="insight-tag">{ind}</span>
                ))}
              </div>
              <span class="insight-meta">{ins.readTime} min · {formatDate(ins.publishDate)}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section insights-newsletter">
    <div class="container">
      <div class="newsletter-box reveal">
        <div class="newsletter-box__text">
          <h2 class="newsletter-box__heading">Get AI + SAP Finance Insights Delivered</h2>
          <p class="newsletter-box__sub">Monthly briefings for finance leaders in utilities, telecom, and insurance. No spam — unsubscribe any time.</p>
        </div>
        <form class="newsletter-box__form" aria-label="Newsletter signup">
          <label for="insights-email" class="sr-only">Your email address</label>
          <input id="insights-email" type="email" class="newsletter-box__input" placeholder="your@company.com" required autocomplete="email" />
          <button type="submit" class="btn btn--primary">Subscribe</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Filter logic
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.insight-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const f = btn.dataset.filter;
      cards.forEach(card => {
        card.style.display = (f === 'all' || card.dataset.format === f) ? '' : 'none';
      });
    });
  });
</script>

<style>
.insights-hero {
  background: linear-gradient(135deg, var(--color-blue) 0%, #0a4a78 100%);
  padding-block: var(--space-20) var(--space-16);
  color: var(--color-white);
}
.insights-hero__inner { max-width: 680px; }
.insights-hero__heading {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  line-height: 1.15;
  color: var(--color-white);
  margin-block: var(--space-4) var(--space-5);
}
.insights-hero__sub { font-size: var(--text-lg); color: rgba(255,255,255,0.8); line-height: 1.65; }

/* Badge variants */
.badge--blue { background: rgba(8,58,94,0.1); color: var(--color-blue); }
.badge--orange { background: rgba(255,142,1,0.12); color: #c47000; }
.badge--green { background: rgba(0,122,63,0.1); color: var(--color-green); }
.badge--grey { background: var(--color-surface); color: var(--color-grey); }
.badge--purple { background: rgba(90,50,140,0.1); color: #5a328c; }

/* Featured */
.featured-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr;
  gap: var(--space-6);
  margin-top: var(--space-8);
}
.featured-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: var(--space-7);
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  transition: box-shadow var(--transition-normal), transform var(--transition-normal);
}
.featured-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
.featured-card--large { border-left: 4px solid var(--color-orange); }
.featured-card__meta { display: flex; gap: var(--space-2); align-items: center; }
.featured-card__title { font-size: var(--text-xl); font-weight: 700; color: var(--color-blue); line-height: 1.35; }
.featured-card--large .featured-card__title { font-size: var(--text-2xl); }
.featured-card__summary { font-size: var(--text-sm); color: var(--color-grey); line-height: 1.7; flex: 1; }
.featured-card__footer { display: flex; align-items: center; justify-content: space-between; padding-top: var(--space-4); border-top: 1px solid var(--color-border); }
.author-info { display: flex; align-items: center; gap: var(--space-3); }
.author-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--color-blue); color: var(--color-white); display: flex; align-items: center; justify-content: center; font-size: var(--text-xs); font-weight: 700; flex-shrink: 0; }
.author-name { display: block; font-size: var(--text-sm); font-weight: 600; color: var(--color-text); }
.author-meta { display: block; font-size: var(--text-xs); color: var(--color-grey); }
.read-more { font-size: var(--text-sm); font-weight: 600; color: var(--color-orange); white-space: nowrap; }

/* Filters */
.insights-all { background: var(--color-surface); }
.insights-filters { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-block: var(--space-6) var(--space-8); }
.filter-btn {
  padding: var(--space-2) var(--space-4);
  border: 1px solid var(--color-border);
  border-radius: 100px;
  background: var(--color-white);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-grey);
  cursor: pointer;
  transition: all var(--transition-fast);
}
.filter-btn:hover { border-color: var(--color-orange); color: var(--color-orange); }
.filter-btn.is-active { background: var(--color-orange); border-color: var(--color-orange); color: var(--color-white); font-weight: 600; }

/* Grid */
.insights-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
}
.insight-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  transition: box-shadow var(--transition-fast), transform var(--transition-fast);
}
.insight-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
.insight-card__top { display: flex; align-items: center; justify-content: space-between; }
.insight-card__gated { display: flex; align-items: center; gap: 4px; font-size: var(--text-xs); color: var(--color-grey); }
.insight-card__title { font-size: var(--text-base); font-weight: 700; color: var(--color-blue); line-height: 1.4; flex: 1; }
.insight-card__summary { font-size: var(--text-sm); color: var(--color-grey); line-height: 1.65; }
.insight-card__footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: var(--space-3); border-top: 1px solid var(--color-border); }
.insight-tags { display: flex; gap: var(--space-1); flex-wrap: wrap; }
.insight-tag { font-size: 11px; background: var(--color-surface); border-radius: 4px; padding: 2px 8px; color: var(--color-grey); font-weight: 500; }
.insight-meta { font-size: var(--text-xs); color: var(--color-grey); white-space: nowrap; }

/* Newsletter */
.newsletter-box {
  background: var(--color-blue);
  border-radius: var(--radius-xl);
  padding: var(--space-10);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-8);
}
.newsletter-box__heading { font-size: var(--text-2xl); font-weight: 700; color: var(--color-white); margin-bottom: var(--space-2); }
.newsletter-box__sub { font-size: var(--text-sm); color: rgba(255,255,255,0.75); }
.newsletter-box__form { display: flex; gap: var(--space-3); min-width: 360px; }
.newsletter-box__input {
  flex: 1;
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.1);
  color: var(--color-white);
  font-size: var(--text-sm);
  outline: none;
  transition: border-color var(--transition-fast);
}
.newsletter-box__input::placeholder { color: rgba(255,255,255,0.4); }
.newsletter-box__input:focus { border-color: var(--color-orange); }

@media (max-width: 1000px) {
  .featured-grid { grid-template-columns: 1fr; }
  .insights-grid { grid-template-columns: repeat(2, 1fr); }
  .newsletter-box { flex-direction: column; }
  .newsletter-box__form { min-width: 0; width: 100%; }
}
@media (max-width: 600px) {
  .insights-grid { grid-template-columns: 1fr; }
}
</style>
