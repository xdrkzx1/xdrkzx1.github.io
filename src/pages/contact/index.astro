---
import BaseLayout from '../../layouts/BaseLayout.astro';

const enquiryTypes = [
  'SAP Finance Transformation',
  'SAP BRIM / Revenue & Billing',
  'AI for SAP Finance',
  'Profitability & Performance',
  'Career / Open Application',
  'Partnership',
  'General Enquiry',
];

const offices = [
  { city: 'Toronto', flag: '🇨🇦', email: 'canada@noshtek.com', phone: '+1 416 555 0100' },
  { city: 'New York', flag: '🇺🇸', email: 'us@noshtek.com', phone: '+1 212 555 0200' },
  { city: 'Singapore', flag: '🇸🇬', email: 'apac@noshtek.com', phone: '+65 6555 0300' },
];
---

<BaseLayout
  title="Contact Us"
  description="Talk to an AI + SAP Finance specialist at Noshtek. Offices in Toronto, New York, and Singapore."
>
  <!-- Hero -->
  <section class="contact-hero">
    <div class="container contact-hero__inner">
      <span class="badge badge--orange">Get in Touch</span>
      <h1 class="contact-hero__heading">Let's Talk About Your SAP Finance Challenge</h1>
      <p class="contact-hero__sub">Whether you're scoping a new programme, need a second opinion on an approach, or want to explore what's possible — our specialists are ready to listen.</p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section contact-main">
    <div class="container contact-layout">

      <!-- Form -->
      <div class="contact-form-wrapper">
        <h2 class="contact-form__heading">Send us a message</h2>
        <p class="contact-form__sub">We typically respond within one business day.</p>

        <form class="contact-form" id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="cf-firstname">First Name <span aria-hidden="true">*</span></label>
              <input class="form-input" id="cf-firstname" type="text" name="firstname" required autocomplete="given-name" />
            </div>
            <div class="form-group">
              <label class="form-label" for="cf-lastname">Last Name <span aria-hidden="true">*</span></label>
              <input class="form-input" id="cf-lastname" type="text" name="lastname" required autocomplete="family-name" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="cf-email">Work Email <span aria-hidden="true">*</span></label>
            <input class="form-input" id="cf-email" type="email" name="email" required autocomplete="email" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="cf-company">Company</label>
              <input class="form-input" id="cf-company" type="text" name="company" autocomplete="organization" />
            </div>
            <div class="form-group">
              <label class="form-label" for="cf-role">Your Role</label>
              <input class="form-input" id="cf-role" type="text" name="role" placeholder="e.g. CFO, VP Finance" />
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="cf-type">What can we help with?</label>
            <select class="form-select" id="cf-type" name="enquiryType">
              <option value="">Select an option...</option>
              {enquiryTypes.map(t => <option value={t}>{t}</option>)}
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="cf-message">Tell us about your challenge <span aria-hidden="true">*</span></label>
            <textarea class="form-textarea" id="cf-message" name="message" rows={5} required placeholder="Describe your SAP landscape, project goals, or challenges — any context helps us respond more meaningfully." />
          </div>
          <div class="form-group form-check">
            <label class="form-check__label">
              <input type="checkbox" name="newsletter" class="form-check__input" />
              <span>Subscribe me to AI + SAP Finance Insights (monthly newsletter)</span>
            </label>
          </div>
          <button type="submit" class="btn btn--primary btn--lg form-submit">
            Send Message
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </button>
          <div id="form-success" class="form-success" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Thank you — we'll be in touch within one business day.
          </div>
        </form>
      </div>

      <!-- Sidebar -->
      <aside class="contact-sidebar">
        <div class="sidebar-block">
          <h3 class="sidebar-block__heading">What happens next?</h3>
          <ol class="next-steps">
            <li>
              <span class="next-step__num">1</span>
              <div>
                <strong>We review your message</strong>
                <p>A relevant specialist reads your enquiry and identifies the right person to respond.</p>
              </div>
            </li>
            <li>
              <span class="next-step__num">2</span>
              <div>
                <strong>You hear back within 1 business day</strong>
                <p>A senior specialist responds with initial thoughts and proposes a call if appropriate.</p>
              </div>
            </li>
            <li>
              <span class="next-step__num">3</span>
              <div>
                <strong>Discovery conversation</strong>
                <p>A focused 30-minute call to understand your situation — no commitment required.</p>
              </div>
            </li>
          </ol>
        </div>

        <div class="sidebar-offices">
          <h3 class="sidebar-offices__heading">Our Offices</h3>
          {offices.map(o => (
            <div class="office-row">
              <span class="office-flag">{o.flag}</span>
              <div>
                <strong class="office-city">{o.city}</strong>
                <a href={`mailto:${o.email}`} class="office-email">{o.email}</a>
                <a href={`tel:${o.phone.replace(/\s/g,'')}`} class="office-phone">{o.phone}</a>
              </div>
            </div>
          ))}
        </div>

        <div class="sidebar-linkedin">
          <a href="https://www.linkedin.com/company/noshtek" target="_blank" rel="noopener noreferrer" class="linkedin-cta">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Follow Noshtek on LinkedIn
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    // In production, POST to your endpoint here
    const btn = form.querySelector('.form-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';
    setTimeout(() => {
      btn.style.display = 'none';
      success.hidden = false;
    }, 800);
  });
</script>

<style>
.contact-hero {
  background: linear-gradient(135deg, var(--color-blue) 0%, #0a4a78 100%);
  padding-block: var(--space-20) var(--space-16);
  color: var(--color-white);
}
.contact-hero__inner { max-width: 680px; }
.contact-hero__heading { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; color: var(--color-white); margin-block: var(--space-4) var(--space-5); }
.contact-hero__sub { font-size: var(--text-lg); color: rgba(255,255,255,0.8); line-height: 1.65; }

/* Layout */
.contact-layout { display: grid; grid-template-columns: 1fr 360px; gap: var(--space-12); align-items: start; }

/* Form */
.contact-form-wrapper { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-8); }
.contact-form__heading { font-size: var(--text-2xl); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-2); }
.contact-form__sub { font-size: var(--text-sm); color: var(--color-grey); margin-bottom: var(--space-7); }
.contact-form { display: flex; flex-direction: column; gap: var(--space-5); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
.form-submit { align-self: flex-start; display: flex; align-items: center; gap: var(--space-2); }
.btn--lg { padding: var(--space-4) var(--space-8); font-size: var(--text-base); }
.form-success { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4); background: rgba(0,122,63,0.08); border: 1px solid rgba(0,122,63,0.25); border-radius: var(--radius-md); color: var(--color-green); font-size: var(--text-sm); font-weight: 600; }
.form-check { display: flex; align-items: flex-start; }
.form-check__label { display: flex; align-items: flex-start; gap: var(--space-3); font-size: var(--text-sm); color: var(--color-grey); cursor: pointer; line-height: 1.5; }
.form-check__input { margin-top: 2px; accent-color: var(--color-orange); flex-shrink: 0; }

/* Sidebar */
.contact-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: var(--space-5); }
.sidebar-block { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-6); }
.sidebar-block__heading { font-size: var(--text-base); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-5); }
.next-steps { list-style: none; display: flex; flex-direction: column; gap: var(--space-5); }
.next-steps li { display: flex; gap: var(--space-4); align-items: flex-start; }
.next-step__num { width: 28px; height: 28px; border-radius: 50%; background: var(--color-orange); color: var(--color-white); display: flex; align-items: center; justify-content: center; font-size: var(--text-xs); font-weight: 800; flex-shrink: 0; }
.next-steps strong { display: block; font-size: var(--text-sm); font-weight: 700; color: var(--color-blue); margin-bottom: 2px; }
.next-steps p { font-size: var(--text-xs); color: var(--color-grey); line-height: 1.6; }

/* Offices */
.sidebar-offices { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-6); }
.sidebar-offices__heading { font-size: var(--text-sm); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-4); }
.office-row { display: flex; align-items: flex-start; gap: var(--space-3); padding-block: var(--space-3); border-bottom: 1px solid var(--color-border); }
.office-row:last-child { border-bottom: none; padding-bottom: 0; }
.office-flag { font-size: 1.4rem; flex-shrink: 0; }
.office-city { display: block; font-size: var(--text-sm); font-weight: 700; color: var(--color-text); }
.office-email, .office-phone { display: block; font-size: var(--text-xs); color: var(--color-grey); text-decoration: none; transition: color var(--transition-fast); }
.office-email:hover, .office-phone:hover { color: var(--color-blue); }

/* LinkedIn */
.linkedin-cta { display: flex; align-items: center; gap: var(--space-3); background: #0077b5; color: var(--color-white); border-radius: var(--radius-lg); padding: var(--space-4) var(--space-5); text-decoration: none; font-size: var(--text-sm); font-weight: 600; transition: opacity var(--transition-fast); }
.linkedin-cta:hover { opacity: 0.9; }

@media (max-width: 1000px) {
  .contact-layout { grid-template-columns: 1fr; }
  .contact-sidebar { position: static; }
}
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
</style>
