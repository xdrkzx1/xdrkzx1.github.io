---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { caseStudies } from '../../data/caseStudies';
import { solutions } from '../../data/solutions';

export function getStaticPaths() {
  return caseStudies.map(c => ({ params: { slug: c.slug }, props: { cs: c } }));
}

const { cs } = Astro.props;
const relSolutions = solutions.filter(s => cs.solutions.includes(s.slug));
const related = caseStudies.filter(c =>
  c.slug !== cs.slug && (c.industry === cs.industry || c.solutions.some(s => cs.solutions.includes(s)))
).slice(0, 2);
---

<BaseLayout
  title={`${cs.client} — Client Story`}
  description={cs.challenge}
>
  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container breadcrumb-inner">
      <a href="/customer-stories">← Customer Stories</a>
      <span class="industry-badge">{cs.industry}</span>
    </div>
  </div>

  <!-- Hero -->
  <section class="cs-detail-hero">
    <div class="container cs-detail-hero__inner">
      <div class="cs-detail-hero__text">
        <div class="cs-detail-hero__meta">
          <span class="cs-industry">{cs.industry}</span>
          <span class="cs-region">{cs.region}</span>
          <span class="cs-timeline">📅 {cs.timeline}</span>
        </div>
        <h1 class="cs-detail-hero__client">{cs.client}</h1>
        <p class="cs-detail-hero__desc">{cs.clientDesc}</p>
      </div>
      <div class="cs-detail-hero__outcomes">
        {cs.outcomes.map(o => (
          <div class="outcome-tile">
            <span class="outcome-tile__value">{o.value}</span>
            <span class="outcome-tile__metric">{o.metric}</span>
            <span class="outcome-tile__desc">{o.description}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Products -->
  <div class="products-bar">
    <div class="container products-bar__inner">
      <span class="products-bar__label">SAP Products Used:</span>
      {cs.sapProducts.map(p => <span class="product-chip">{p}</span>)}
    </div>
  </div>

  <!-- Challenge / Approach -->
  <section class="section">
    <div class="container cs-content">
      <div class="cs-main">
        <div class="cs-section">
          <h2 class="cs-section__heading">
            <span class="cs-section__num">01</span>
            The Challenge
          </h2>
          <p class="cs-section__text">{cs.challenge}</p>
        </div>
        <div class="cs-section">
          <h2 class="cs-section__heading">
            <span class="cs-section__num">02</span>
            Our Approach
          </h2>
          <p class="cs-section__text">{cs.approach}</p>
        </div>

        {cs.testimonial && (
          <blockquote class="cs-testimonial">
            <p class="cs-testimonial__quote">"{cs.testimonial.quote}"</p>
            <footer class="cs-testimonial__author">
              <div class="cs-testimonial__avatar">
                {cs.testimonial.name.split(' ').map(n => n[0]).join('').slice(0,2)}
              </div>
              <div>
                <span class="cs-testimonial__name">{cs.testimonial.name}</span>
                <span class="cs-testimonial__role">{cs.testimonial.role}</span>
              </div>
            </footer>
          </blockquote>
        )}
      </div>

      <aside class="cs-sidebar">
        {relSolutions.length > 0 && (
          <div class="sidebar-block">
            <p class="sidebar-block__label">Solutions Delivered</p>
            <div class="sidebar-solutions">
              {relSolutions.map(s => (
                <a href={`/solutions/${s.slug}`} class="sidebar-sol">
                  <span>{s.icon}</span>
                  <span>{s.shortTitle}</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                </a>
              ))}
            </div>
          </div>
        )}
        <div class="sidebar-block">
          <p class="sidebar-block__label">Industry</p>
          <p class="sidebar-value">{cs.industry}</p>
        </div>
        <div class="sidebar-block">
          <p class="sidebar-block__label">Region</p>
          <p class="sidebar-value">{cs.region}</p>
        </div>
        <div class="sidebar-block">
          <p class="sidebar-block__label">Programme Duration</p>
          <p class="sidebar-value">{cs.timeline}</p>
        </div>
        <div class="sidebar-cta">
          <p class="sidebar-cta__text">Want similar results?</p>
          <a href="/contact" class="btn btn--primary btn--sm btn--full">Talk to a Specialist</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Key Results -->
  <section class="section cs-results">
    <div class="container">
      <div class="section-label reveal">Results</div>
      <h2 class="section-heading reveal">Key Outcomes</h2>
      <div class="results-grid">
        {cs.outcomes.map((o, i) => (
          <div class={`result-card reveal reveal-delay-${i + 1}`}>
            <span class="result-card__value">{o.value}</span>
            <span class="result-card__metric">{o.metric}</span>
            <p class="result-card__desc">{o.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  {related.length > 0 && (
    <section class="section cs-related">
      <div class="container">
        <h2 class="section-heading reveal">More Client Stories</h2>
        <div class="related-cs-grid">
          {related.map(r => (
            <a href={`/customer-stories/${r.slug}`} class="related-cs reveal">
              <div class="related-cs__meta">
                <span class="related-cs__industry">{r.industry}</span>
                <span class="related-cs__region">{r.region}</span>
              </div>
              <h3 class="related-cs__client">{r.client}</h3>
              <p class="related-cs__challenge">{r.challenge}</p>
              <div class="related-cs__outcomes">
                {r.outcomes.slice(0,2).map(o => (
                  <div class="rc-outcome">
                    <span class="rc-outcome__value">{o.value}</span>
                    <span class="rc-outcome__label">{o.metric}</span>
                  </div>
                ))}
              </div>
            </a>
          ))}
        </div>
        <div class="section-action reveal">
          <a href="/customer-stories" class="btn btn--secondary">View All Stories</a>
        </div>
      </div>
    </section>
  )}

  <section class="cta-banner reveal">
    <div class="container cta-banner__inner">
      <div class="cta-banner__text">
        <h2 class="cta-banner__heading">Ready to achieve similar results?</h2>
        <p class="cta-banner__sub">Our specialists will help you assess what's achievable in your SAP environment.</p>
      </div>
      <div class="cta-banner__actions">
        <a href="/contact" class="btn btn--white">Request a Consultation</a>
        <a href="/solutions" class="btn btn--outline-white">Explore Our Solutions</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.breadcrumb-bar { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding-block: var(--space-3); }
.breadcrumb-inner { display: flex; align-items: center; gap: var(--space-4); }
.breadcrumb-inner a { font-size: var(--text-sm); color: var(--color-grey); text-decoration: none; transition: color var(--transition-fast); }
.breadcrumb-inner a:hover { color: var(--color-blue); }
.industry-badge { background: rgba(255,142,1,0.12); color: #c47000; padding: 4px 12px; border-radius: 100px; font-size: var(--text-xs); font-weight: 600; }

/* Hero */
.cs-detail-hero { background: linear-gradient(135deg, var(--color-blue) 0%, #0a4a78 100%); padding-block: var(--space-16); color: var(--color-white); }
.cs-detail-hero__inner { display: grid; grid-template-columns: 1fr 400px; gap: var(--space-12); align-items: start; }
.cs-detail-hero__meta { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center; margin-bottom: var(--space-4); }
.cs-industry { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-orange); }
.cs-region { font-size: var(--text-xs); color: rgba(255,255,255,0.6); }
.cs-timeline { font-size: var(--text-xs); color: rgba(255,255,255,0.7); }
.cs-detail-hero__client { font-size: clamp(1.6rem, 3.5vw, 2.5rem); font-weight: 800; line-height: 1.15; color: var(--color-white); margin-bottom: var(--space-4); }
.cs-detail-hero__desc { font-size: var(--text-base); color: rgba(255,255,255,0.8); line-height: 1.7; }
.cs-detail-hero__outcomes { display: flex; flex-direction: column; gap: var(--space-4); }
.outcome-tile { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: var(--radius-lg); padding: var(--space-5); }
.outcome-tile__value { display: block; font-family: var(--font-heading); font-weight: 800; font-size: var(--text-2xl); color: var(--color-orange); line-height: 1; margin-bottom: 2px; }
.outcome-tile__metric { display: block; font-size: var(--text-sm); font-weight: 600; color: var(--color-white); margin-bottom: 4px; }
.outcome-tile__desc { font-size: var(--text-xs); color: rgba(255,255,255,0.65); }

/* Products bar */
.products-bar { background: var(--color-surface); border-bottom: 1px solid var(--color-border); padding-block: var(--space-3); }
.products-bar__inner { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
.products-bar__label { font-size: var(--text-xs); font-weight: 700; color: var(--color-grey); text-transform: uppercase; letter-spacing: 0.06em; }
.product-chip { font-size: var(--text-xs); background: rgba(8,58,94,0.08); color: var(--color-blue); border-radius: var(--radius-sm); padding: 4px 10px; font-weight: 600; }

/* Content layout */
.cs-content { display: grid; grid-template-columns: 1fr 280px; gap: var(--space-12); align-items: start; }
.cs-main { display: flex; flex-direction: column; gap: var(--space-10); }
.cs-section__heading { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-xl); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-4); }
.cs-section__num { font-size: var(--text-3xl); font-weight: 800; color: rgba(8,58,94,0.12); line-height: 1; }
.cs-section__text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; }

/* Testimonial */
.cs-testimonial { border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-8); margin: 0; border-left: 4px solid var(--color-orange); }
.cs-testimonial__quote { font-size: var(--text-lg); color: var(--color-text); font-style: italic; line-height: 1.65; margin-bottom: var(--space-6); }
.cs-testimonial__author { display: flex; align-items: center; gap: var(--space-3); }
.cs-testimonial__avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--color-blue); color: var(--color-white); display: flex; align-items: center; justify-content: center; font-size: var(--text-sm); font-weight: 700; flex-shrink: 0; }
.cs-testimonial__name { display: block; font-weight: 700; color: var(--color-blue); }
.cs-testimonial__role { display: block; font-size: var(--text-sm); color: var(--color-grey); }

/* Sidebar */
.cs-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: var(--space-4); }
.sidebar-block { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-5); }
.sidebar-block__label { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-grey); margin-bottom: var(--space-3); }
.sidebar-value { font-size: var(--text-sm); color: var(--color-text); font-weight: 500; }
.sidebar-solutions { display: flex; flex-direction: column; gap: var(--space-2); }
.sidebar-sol { display: flex; align-items: center; gap: var(--space-2); text-decoration: none; font-size: var(--text-sm); color: var(--color-blue); font-weight: 500; padding: var(--space-2); border-radius: var(--radius-sm); transition: background var(--transition-fast); }
.sidebar-sol:hover { background: var(--color-surface); }
.sidebar-sol > svg { margin-left: auto; color: var(--color-grey); }
.sidebar-cta { background: var(--color-blue); border-radius: var(--radius-lg); padding: var(--space-5); }
.sidebar-cta__text { font-size: var(--text-sm); color: rgba(255,255,255,0.85); margin-bottom: var(--space-3); }
.btn--full { width: 100%; justify-content: center; }

/* Results */
.cs-results { background: var(--color-surface); }
.results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); margin-top: var(--space-10); }
.result-card { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); border-top: 3px solid var(--color-orange); }
.result-card__value { display: block; font-family: var(--font-heading); font-weight: 800; font-size: var(--text-2xl); color: var(--color-orange); line-height: 1; margin-bottom: var(--space-1); }
.result-card__metric { display: block; font-size: var(--text-sm); font-weight: 700; color: var(--color-blue); margin-bottom: var(--space-2); }
.result-card__desc { font-size: var(--text-sm); color: var(--color-grey); line-height: 1.6; }

/* Related */
.cs-related { background: var(--color-surface); }
.related-cs-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6); margin-top: var(--space-8); }
.related-cs { background: var(--color-white); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-7); text-decoration: none; display: flex; flex-direction: column; gap: var(--space-4); transition: box-shadow var(--transition-fast), transform var(--transition-fast); }
.related-cs:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }
.related-cs__meta { display: flex; gap: var(--space-3); }
.related-cs__industry { font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; color: var(--color-orange); letter-spacing: 0.06em; }
.related-cs__region { font-size: var(--text-xs); color: var(--color-grey); }
.related-cs__client { font-size: var(--text-lg); font-weight: 700; color: var(--color-blue); }
.related-cs__challenge { font-size: var(--text-sm); color: var(--color-grey); line-height: 1.65; }
.related-cs__outcomes { display: flex; gap: var(--space-5); border-top: 1px solid var(--color-border); padding-top: var(--space-4); }
.rc-outcome__value { display: block; font-family: var(--font-heading); font-weight: 800; font-size: var(--text-xl); color: var(--color-blue); }
.rc-outcome__label { font-size: var(--text-xs); color: var(--color-grey); }
.section-action { text-align: center; margin-top: var(--space-8); }

@media (max-width: 1000px) {
  .cs-detail-hero__inner { grid-template-columns: 1fr; }
  .cs-detail-hero__outcomes { flex-direction: row; flex-wrap: wrap; }
  .outcome-tile { flex: 1; min-width: 160px; }
  .cs-content { grid-template-columns: 1fr; }
  .cs-sidebar { position: static; }
  .results-grid { grid-template-columns: repeat(2, 1fr); }
  .related-cs-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) { .results-grid { grid-template-columns: 1fr; } }
</style>
