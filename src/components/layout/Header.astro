---
const navLinks = [
  {
    label: 'Solutions',
    href: '/solutions',
    mega: true,
    cols: [
      {
        heading: 'Financial Transformation',
        items: [
          { label: 'SAP S/4HANA Finance & Central Finance', href: '/solutions/financial-transformation' },
          { label: 'SAP FPSL / Treasury & Risk Management', href: '/solutions/financial-transformation#treasury' },
          { label: 'IFRS 17 & Regulatory Reporting', href: '/solutions/financial-transformation#ifrs17' },
        ],
      },
      {
        heading: 'Intelligent Revenue & Billing',
        items: [
          { label: 'SAP BRIM / FI-CA / FS-CD', href: '/solutions/intelligent-revenue-billing' },
          { label: 'Subscription & Usage-Based Billing', href: '/solutions/intelligent-revenue-billing#subscription' },
        ],
      },
      {
        heading: 'Profitability & Performance',
        items: [
          { label: 'SAP PaPM', href: '/solutions/profitability-performance' },
          { label: 'SAP Analytics Cloud', href: '/solutions/profitability-performance#analytics' },
        ],
      },
      {
        heading: 'AI for SAP Finance',
        items: [
          { label: 'AI Accelerators for Finance', href: '/solutions/ai-for-sap-finance' },
          { label: 'BTP & Data Foundation', href: '/solutions/ai-for-sap-finance#btp' },
        ],
      },
    ],
  },
  {
    label: 'Industries',
    href: '/industries',
    mega: true,
    cols: [
      {
        heading: 'Sectors We Serve',
        items: [
          { label: 'Insurance', href: '/industries/insurance', desc: 'IFRS 17, BRIM, regulatory compliance' },
          { label: 'Utilities', href: '/industries/utilities', desc: 'Usage billing, S/4HANA, smart grid finance' },
          { label: 'Telecom', href: '/industries/telecom', desc: 'Subscription billing, revenue assurance' },
        ],
      },
    ],
  },
  { label: 'Insights',         href: '/insights' },
  { label: 'Customer Stories', href: '/customer-stories' },
  { label: 'Partners',         href: '/partners' },
  {
    label: 'Company',
    href: '/company',
    mega: false,
    dropdown: [
      { label: 'About Noshtek',     href: '/company' },
      { label: 'Leadership & Experts', href: '/company/leadership' },
      { label: 'Locations',         href: '/company/locations' },
      { label: 'Careers',           href: '/careers' },
    ],
  },
  { label: 'Careers', href: '/careers' },
];
---

<header class="site-header" id="site-header" role="banner">
  <div class="header-inner container">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="Noshtek — Home">
      <!-- Icon mark (dark/navy version for light header bg) -->
      <svg class="logo-icon" viewBox="0 0 2880 2880" aria-hidden="true" focusable="false">
        <path fill="#083a5e" d="M 662.167969 1439.949219 L 1369.445312 2147.230469 C 1205.421875 2311.265625 939.480469 2311.265625 775.445312 2147.230469 L 68.167969 1439.949219 L 775.445312 732.671875 C 939.480469 568.636719 1205.421875 568.636719 1369.445312 732.671875 Z"/>
        <path fill="#000000" d="M 2811.824219 1439.949219 L 2072.867188 2178.910156 C 1926.316406 2325.457031 1688.753906 2325.457031 1542.167969 2178.910156 L 1439.996094 2076.691406 L 803.246094 1439.949219 L 1439.996094 803.210938 L 1542.195312 700.992188 C 1688.746094 554.445312 1926.308594 554.445312 2072.894531 700.992188 Z"/>
        <path fill="#ff8e01" d="M 2811.824219 1439.949219 L 2090.644531 2161.140625 L 2072.867188 2178.910156 C 1926.316406 2325.457031 1688.753906 2325.457031 1542.167969 2178.910156 L 1439.996094 2076.691406 L 803.246094 1439.949219 L 1439.996094 803.210938 L 1542.195312 700.992188 C 1688.746094 554.445312 1926.308594 554.445312 2072.894531 700.992188 L 2090.644531 718.742188 Z"/>
      </svg>
      <span class="logo-wordmark">NOSHTEK</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header-nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navLinks.filter(l => l.label !== 'Careers').map((link) => (
          <li class={`nav-item ${link.mega || link.dropdown ? 'has-dropdown' : ''}`}>
            {link.mega || link.dropdown ? (
              <button
                class="nav-link nav-link--trigger"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.label}
                <svg class="nav-chevron" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
            ) : (
              <a href={link.href} class="nav-link">{link.label}</a>
            )}

            {/* Mega menu */}
            {link.mega && link.cols && (
              <div class="mega-menu" role="region" aria-label={`${link.label} submenu`}>
                <div class="mega-menu__inner container">
                  {link.cols.map((col) => (
                    <div class="mega-col">
                      <p class="mega-col__heading">{col.heading}</p>
                      <ul role="list">
                        {col.items.map((item) => (
                          <li>
                            <a href={item.href} class="mega-link">
                              {item.label}
                              {item.desc && <span class="mega-link__desc">{item.desc}</span>}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Simple dropdown */}
            {!link.mega && link.dropdown && (
              <ul class="simple-dropdown" role="list">
                {link.dropdown.map((item) => (
                  <li>
                    <a href={item.href} class="dropdown-link">{item.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <!-- Desktop CTA -->
    <a href="/contact" class="btn btn--primary header-cta">
      Talk to an SAP + AI Specialist
    </a>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburger" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
      <span class="hamburger__line"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul role="list">
        {navLinks.map((link) => (
          <li class="mobile-nav-item">
            {link.mega || link.dropdown ? (
              <>
                <button class="mobile-nav-link mobile-nav-link--accordion" aria-expanded="false">
                  {link.label}
                  <svg class="nav-chevron" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <ul class="mobile-submenu" role="list">
                  {(link.mega ? link.cols?.flatMap(c => c.items) : link.dropdown)?.map((item) => (
                    <li>
                      <a href={item.href} class="mobile-submenu-link">{item.label}</a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a href={link.href} class="mobile-nav-link">{link.label}</a>
            )}
          </li>
        ))}
        <li>
          <a href="/contact" class="btn btn--primary" style="width:100%; justify-content:center; margin-top:1rem;">
            Talk to an SAP + AI Specialist
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
/* ---- Header shell ---- */
.site-header {
  position: sticky;
  top: 0;
  z-index: var(--z-header);
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  transition: box-shadow var(--transition-base), background var(--transition-base);
}

.site-header.scrolled {
  box-shadow: var(--shadow-md);
}

.header-inner {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  height: var(--header-height);
}

/* ---- Logo ---- */
.header-logo {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  text-decoration: none;
  flex-shrink: 0;
}

.logo-icon {
  width: 36px;
  height: 36px;
}

.logo-wordmark {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: var(--text-xl);
  letter-spacing: 0.06em;
  color: var(--color-blue);
}

/* ---- Desktop nav ---- */
.header-nav {
  flex: 1;
  display: flex;
  justify-content: center;
}

.nav-list {
  display: flex;
  align-items: center;
  gap: var(--space-1);
}

.nav-item {
  position: relative;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: var(--space-2) var(--space-3);
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-grey-dark);
  background: none;
  border: none;
  cursor: pointer;
  border-radius: var(--radius-md);
  transition: color var(--transition-fast), background var(--transition-fast);
  white-space: nowrap;
  text-decoration: none;
}

.nav-link:hover,
.nav-link--trigger[aria-expanded="true"] {
  color: var(--color-blue);
  background: var(--color-blue-50);
}

.nav-chevron {
  transition: transform var(--transition-fast);
  flex-shrink: 0;
}

.nav-link--trigger[aria-expanded="true"] .nav-chevron {
  transform: rotate(180deg);
}

/* ---- Mega menu ---- */
.mega-menu {
  display: none;
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  min-width: 720px;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-xl);
  padding: var(--space-6);
  padding-top: calc(var(--space-6) + 8px);
  margin-top: 0;
  animation: fadeInUp 0.2s ease;
}

/* Invisible bridge fills gap between nav item and menu panel */
.mega-menu::before {
  content: '';
  position: absolute;
  top: -8px;
  left: 0;
  right: 0;
  height: 8px;
}

.has-dropdown:hover .mega-menu,
.has-dropdown:focus-within .mega-menu,
.mega-menu:hover {
  display: block;
}

.nav-link--trigger[aria-expanded="true"] ~ .mega-menu {
  display: block;
}

.mega-menu__inner {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: var(--space-6);
  padding: 0;
}

.mega-col__heading {
  font-family: var(--font-heading);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 1px solid var(--color-border);
}

.mega-link {
  display: flex;
  flex-direction: column;
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-grey-dark);
  text-decoration: none;
  transition: all var(--transition-fast);
  margin-bottom: var(--space-1);
}

.mega-link:hover {
  background: var(--color-blue-50);
  color: var(--color-blue);
}

.mega-link__desc {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  font-weight: 400;
  margin-top: 2px;
}

/* ---- Simple dropdown ---- */
.simple-dropdown {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 200px;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  padding: var(--space-2);
  padding-top: calc(var(--space-2) + 8px);
  animation: fadeInUp 0.2s ease;
}

.simple-dropdown::before {
  content: '';
  position: absolute;
  top: -8px;
  left: 0;
  right: 0;
  height: 8px;
}

.has-dropdown:hover .simple-dropdown,
.has-dropdown:focus-within .simple-dropdown,
.nav-link--trigger[aria-expanded="true"] ~ .simple-dropdown {
  display: block;
}

.dropdown-link {
  display: block;
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-grey-dark);
  text-decoration: none;
  transition: all var(--transition-fast);
}

.dropdown-link:hover {
  background: var(--color-blue-50);
  color: var(--color-blue);
}

/* ---- Header CTA ---- */
.header-cta {
  flex-shrink: 0;
  font-size: var(--text-xs);
  padding: var(--space-2) var(--space-4);
}

/* ---- Hamburger ---- */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 44px;
  height: 44px;
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-2);
  border-radius: var(--radius-md);
  transition: background var(--transition-fast);
  flex-shrink: 0;
}

.hamburger:hover { background: var(--color-blue-50); }

.hamburger__line {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--color-blue);
  border-radius: var(--radius-full);
  transition: transform var(--transition-base), opacity var(--transition-base);
}

.hamburger[aria-expanded="true"] .hamburger__line:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.hamburger[aria-expanded="true"] .hamburger__line:nth-child(2) {
  opacity: 0;
}
.hamburger[aria-expanded="true"] .hamburger__line:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* ---- Mobile menu ---- */
.mobile-menu {
  display: none;
  background: var(--color-white);
  border-top: 1px solid var(--color-border);
  padding: var(--space-4) var(--space-6) var(--space-8);
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}

.mobile-menu.is-open {
  max-height: 90vh;
  overflow-y: auto;
}

.mobile-nav-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: var(--space-3) 0;
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: var(--text-base);
  color: var(--color-text);
  background: none;
  border: none;
  border-bottom: 1px solid var(--color-border);
  cursor: pointer;
  text-decoration: none;
  transition: color var(--transition-fast);
}

.mobile-nav-link:hover { color: var(--color-blue); }

.mobile-submenu {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-md);
  margin-top: var(--space-1);
}

.mobile-submenu.is-open { max-height: 600px; }

.mobile-submenu-link {
  display: block;
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-sm);
  color: var(--color-grey-dark);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.mobile-submenu-link:hover { color: var(--color-blue); }

/* ---- Responsive ---- */
@media (max-width: 1100px) {
  .header-nav   { display: none; }
  .header-cta   { display: none; }
  .hamburger    { display: flex; }
  .mobile-menu  { display: block; }
  .header-inner { justify-content: space-between; }
}
</style>

<script>
  const header = document.getElementById('site-header')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  // Sticky scroll effect
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu.setAttribute('aria-hidden', String(isOpen));
    mobileMenu.classList.toggle('is-open', !isOpen);
  });

  // Mobile accordion sub-menus
  document.querySelectorAll('.mobile-nav-link--accordion').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const sub = btn.nextElementSibling as HTMLElement;
      sub?.classList.toggle('is-open', !expanded);
      const chevron = btn.querySelector('.nav-chevron') as HTMLElement;
      if (chevron) chevron.style.transform = expanded ? '' : 'rotate(180deg)';
    });
  });

  // Desktop dropdown keyboard accessibility
  document.querySelectorAll('.nav-link--trigger').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      // Close all others
      document.querySelectorAll('.nav-link--trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });

  // Close dropdowns on outside click
  document.addEventListener('click', () => {
    document.querySelectorAll('.nav-link--trigger').forEach(b => b.setAttribute('aria-expanded', 'false'));
  });
</script>
