---
const year = new Date().getFullYear();

const cols = [
  {
    heading: 'Solutions',
    links: [
      { label: 'Financial Transformation',      href: '/solutions/financial-transformation' },
      { label: 'Intelligent Revenue & Billing', href: '/solutions/intelligent-revenue-billing' },
      { label: 'Profitability & Performance',   href: '/solutions/profitability-performance' },
      { label: 'AI for SAP Finance',            href: '/solutions/ai-for-sap-finance' },
    ],
  },
  {
    heading: 'Industries',
    links: [
      { label: 'Insurance',  href: '/industries/insurance' },
      { label: 'Utilities',  href: '/industries/utilities' },
      { label: 'Telecom',    href: '/industries/telecom' },
      { label: 'All Industries', href: '/industries' },
    ],
  },
  {
    heading: 'Insights',
    links: [
      { label: 'Articles & Reports',   href: '/insights' },
      { label: 'Customer Stories',     href: '/customer-stories' },
      { label: 'Webinars & Events',    href: '/insights?format=webinar' },
      { label: 'Guides & Checklists',  href: '/insights?format=guide' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'About Noshtek',        href: '/company' },
      { label: 'Leadership & Experts', href: '/company/leadership' },
      { label: 'Partners',             href: '/partners' },
      { label: 'Careers',              href: '/careers' },
      { label: 'Locations',            href: '/company/locations' },
    ],
  },
];
---

<footer class="site-footer" role="contentinfo">
  <!-- Top band -->
  <div class="footer-top">
    <div class="container footer-top__inner">
      <!-- Brand col -->
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="Noshtek — Home">
          <svg class="footer-logo__icon" viewBox="0 0 2880 2880" aria-hidden="true">
            <path fill="#ffffff" d="M 662.167969 1439.953125 L 1369.445312 2147.230469 C 1205.421875 2311.265625 939.480469 2311.265625 775.445312 2147.230469 L 68.167969 1439.953125 L 775.445312 732.671875 C 939.480469 568.640625 1205.421875 568.640625 1369.445312 732.671875 Z"/>
            <path fill="#2a2a2a" d="M 2811.824219 1439.953125 L 2072.867188 2178.910156 C 1926.316406 2325.457031 1688.753906 2325.457031 1542.167969 2178.910156 L 1439.996094 2076.691406 L 803.246094 1439.953125 L 1439.996094 803.210938 L 1542.195312 700.992188 C 1688.746094 554.445312 1926.308594 554.445312 2072.894531 700.992188 Z"/>
            <path fill="#ff8e01" d="M 2811.824219 1439.953125 L 2090.644531 2161.140625 L 2072.867188 2178.910156 C 1926.316406 2325.457031 1688.753906 2325.457031 1542.167969 2178.910156 L 1439.996094 2076.691406 L 803.246094 1439.953125 L 1439.996094 803.210938 L 1542.195312 700.992188 C 1688.746094 554.445312 1926.308594 554.445312 2072.894531 700.992188 L 2090.644531 718.746094 Z"/>
          </svg>
          <span class="footer-logo__text">NOSHTEK</span>
        </a>
        <p class="footer-tagline">AI + SAP Financial Transformation for regulated industries.</p>

        <!-- Newsletter -->
        <div class="footer-newsletter">
          <p class="footer-newsletter__label">Subscribe to AI + SAP Finance Insights</p>
          <form class="footer-newsletter__form" aria-label="Newsletter signup">
            <label for="footer-email" class="sr-only">Your email address</label>
            <input
              id="footer-email"
              type="email"
              class="footer-newsletter__input"
              placeholder="your@company.com"
              required
              autocomplete="email"
            />
            <button type="submit" class="btn btn--primary btn--sm">Subscribe</button>
          </form>
        </div>

        <!-- Social -->
        <div class="footer-social" aria-label="Noshtek social media">
          <a href="https://www.linkedin.com/company/noshtek" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Noshtek on LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://twitter.com/noshtek" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Noshtek on Twitter / X">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link cols -->
      {cols.map((col) => (
        <div class="footer-col">
          <p class="footer-col__heading">{col.heading}</p>
          <ul role="list">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p class="footer-copy">
        &copy; {year} Noshtek. All rights reserved. SAP and related marks are trademarks of SAP SE.
      </p>
      <nav class="footer-legal" aria-label="Legal links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/cookies">Cookie Policy</a>
      </nav>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--color-blue-dark);
  color: rgba(255,255,255,0.85);
}

/* Top */
.footer-top {
  padding-block: var(--space-16) var(--space-12);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.footer-top__inner {
  display: grid;
  grid-template-columns: 1.8fr repeat(4, 1fr);
  gap: var(--space-10);
  align-items: start;
}

/* Brand */
.footer-logo {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  text-decoration: none;
  margin-bottom: var(--space-4);
}

.footer-logo__icon {
  width: 32px;
  height: 32px;
}

.footer-logo__text {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: var(--text-xl);
  letter-spacing: 0.06em;
  color: var(--color-white);
}

.footer-tagline {
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.6);
  line-height: 1.6;
  margin-bottom: var(--space-6);
  max-width: 260px;
}

/* Newsletter */
.footer-newsletter__label {
  font-family: var(--font-heading);
  font-size: var(--text-sm);
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  margin-bottom: var(--space-2);
}

.footer-newsletter__form {
  display: flex;
  gap: var(--space-2);
  margin-bottom: var(--space-6);
}

.footer-newsletter__input {
  flex: 1;
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.08);
  color: var(--color-white);
  font-size: var(--text-sm);
  outline: none;
  transition: border-color var(--transition-fast);
}

.footer-newsletter__input::placeholder { color: rgba(255,255,255,0.4); }
.footer-newsletter__input:focus { border-color: var(--color-orange); }

/* Social */
.footer-social {
  display: flex;
  gap: var(--space-3);
}

.social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.7);
  transition: all var(--transition-fast);
}

.social-link:hover {
  background: var(--color-orange);
  color: var(--color-white);
  transform: translateY(-2px);
}

/* Link cols */
.footer-col__heading {
  font-family: var(--font-heading);
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-orange);
  margin-bottom: var(--space-4);
}

.footer-link {
  display: block;
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.65);
  text-decoration: none;
  padding-block: var(--space-1);
  transition: color var(--transition-fast);
  line-height: 1.6;
}

.footer-link:hover { color: var(--color-white); }

/* Bottom bar */
.footer-bottom {
  padding-block: var(--space-5);
}

.footer-bottom__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.footer-copy {
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.4);
}

.footer-legal {
  display: flex;
  gap: var(--space-4);
}

.footer-legal a {
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.4);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.footer-legal a:hover { color: rgba(255,255,255,0.8); }

/* Responsive */
@media (max-width: 1100px) {
  .footer-top__inner {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
  .footer-brand { grid-column: 1 / -1; }
}

@media (max-width: 600px) {
  .footer-top__inner { grid-template-columns: 1fr 1fr; }
  .footer-bottom__inner { flex-direction: column; text-align: center; }
  .footer-newsletter__form { flex-direction: column; }
}
</style>
